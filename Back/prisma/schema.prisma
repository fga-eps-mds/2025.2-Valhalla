// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model Usuario {
  id  Int   @id @default(autoincrement())
  nome String
  email String
  senha String
  cargo CargoUsuario
  isAdmin Boolean
  admMaster Boolean
  mediasrc String?
  dataDelete DateTime?
  denuncias Denuncia[]
  comentarios Comentario[]
  noticias Noticia[]
  reportsDenuncia ReportsDenuncia[]
  apoiosDenuncia ApoiosDenuncia[]
  reportsComentario ReportsComentario[]
  apoiosComentario ApoiosComentario[]
}

enum CargoUsuario {
  ESTUDANTE
  SERVIDOR
  OUTRO
}

model Denuncia {
  id Int @id @default(autoincrement())
  idUsuario Int
  descricao String
  idCategoria Int
  mediasrc String?
  anonimato Boolean @default(false)
  dataDelete DateTime?
  dataCriacao DateTime @default(now())
  dataUpdate DateTime @updatedAt
  comentarios Comentario []
  reportsDenuncia ReportsDenuncia[]
  apoiosDenuncia ApoiosDenuncia[]
  usuario  Usuario @relation(fields: [idUsuario], references: [id], onUpdate: Cascade)
  categoria Categoria @relation(fields: [idCategoria], references: [id], onUpdate: Cascade)
}

model Comentario{
  id Int @id @default(autoincrement())
  idUsuario Int
  idDenuncia Int
  Descricao String
  anonimato Boolean @default(false)
  dataDelete DateTime?
  dataCriacao DateTime @default(now())
  dataUpdate DateTime @updatedAt
  reportsComentario ReportsComentario[]
  apoiosComentario ApoiosComentario[]
  usuario Usuario @relation(fields: [idUsuario], references: [id], onUpdate: Cascade)
  denuncia Denuncia @relation(fields: [idDenuncia], references: [id], onUpdate: Cascade)
}

model Noticia {
  id Int @id @default(autoincrement())
  idUsuario Int
  descricao String
  tipo String
  mediasrc String?
  dataDelete DateTime?
  dataCriacao DateTime @default(now())
  dataUpdate DateTime @updatedAt
  usuario Usuario @relation(fields: [idUsuario], references: [id], onUpdate: Cascade)
  }

model Categoria {
  id Int @id @default(autoincrement())
  nome String @unique
  denuncias Denuncia[]
}

model ApoiosDenuncia {
  id Int @id @default(autoincrement())
  idUsuario Int
  idDenuncia Int
  usuario Usuario @relation(fields: [idUsuario], references: [id], onUpdate: Cascade)
  denuncia Denuncia @relation(fields: [idDenuncia], references: [id], onUpdate: Cascade)
  @@unique([idUsuario, idDenuncia])
}

model ReportsDenuncia {
  id Int @id @default(autoincrement())
  idUsuario Int
  idDenuncia Int
  usuario Usuario @relation(fields: [idUsuario], references: [id], onUpdate: Cascade)
  denuncia Denuncia @relation(fields: [idDenuncia], references: [id], onUpdate: Cascade)
  @@unique([idUsuario, idDenuncia])
}

model ApoiosComentario {
  id Int @id @default(autoincrement())
  idUsuario Int
  idComentario Int
  usuario Usuario @relation(fields: [idUsuario], references: [id], onUpdate: Cascade)
  comentario Comentario @relation(fields: [idComentario], references: [id], onUpdate: Cascade)
  @@unique([idUsuario, idComentario])
}

model ReportsComentario {
  id Int @id @default(autoincrement())
  idUsuario Int
  idComentario Int
  usuario Usuario @relation(fields: [idUsuario], references: [id], onUpdate: Cascade)
  comentario Comentario @relation(fields: [idComentario], references: [id], onUpdate: Cascade)
  @@unique([idUsuario, idComentario])
}