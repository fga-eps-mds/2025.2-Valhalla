// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model Usuario {
  id  Int   @id @default(autoincrement())
  nome String
  email String // Não será único para permitir usuários deletados com o mesmo email, aplicando assim um soft delete adicionado linha no SQL: CREATE UNIQUE INDEX "Usuario_unique_active_email_idx" ON "Usuario"("email") WHERE "dataDelete" IS NULL;
  senha String
  cargo CargoUsuario
  tipo TipoUsuario @default(COMUM)
  mediaSrc String?
  dataDelete DateTime?
  dataCriacao DateTime @default(now())
  dataUpdate DateTime @updatedAt
  denuncias Denuncia[]
  comentarios Comentario[]
  noticias Noticia[]
  reportsDenuncia ReportsDenuncia[]
  apoiosDenuncia ApoiosDenuncia[]
  reportsComentario ReportsComentario[]
  apoiosComentario ApoiosComentario[]
}

enum CargoUsuario {
  ESTUDANTE
  SERVIDOR
  OUTRO
}

enum TipoUsuario {
  COMUM
  ADMIN
  ADMINMASTER
}

model Denuncia {
  id Int @id @default(autoincrement())
  idUsuario Int
  descricao String
  idCategoria Int
  mediaSrc String?
  anonimato Boolean @default(false)
  dataDelete DateTime?
  dataCriacao DateTime @default(now())
  dataUpdate DateTime @updatedAt
  comentarios Comentario []
  reportsDenuncia ReportsDenuncia[]
  apoiosDenuncia ApoiosDenuncia[]
  usuario  Usuario @relation(fields: [idUsuario], references: [id], onDelete: Cascade, onUpdate: Cascade)
  categoria Categoria @relation(fields: [idCategoria], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model Comentario{
  id Int @id @default(autoincrement())
  idUsuario Int
  idDenuncia Int
  descricao String
  anonimato Boolean @default(false)
  dataDelete DateTime?
  dataCriacao DateTime @default(now())
  dataUpdate DateTime @updatedAt
  reportsComentario ReportsComentario[]
  apoiosComentario ApoiosComentario[]
  usuario Usuario @relation(fields: [idUsuario], references: [id], onDelete: Cascade, onUpdate: Cascade)
  denuncia Denuncia @relation(fields: [idDenuncia], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model Noticia {
  id Int @id @default(autoincrement())
  idUsuario Int
  descricao String
  tipo TipoNoticia
  mediaSrc String?
  dataDelete DateTime?
  dataCriacao DateTime @default(now())
  dataUpdate DateTime @updatedAt
  usuario Usuario @relation(fields: [idUsuario], references: [id], onDelete: Cascade, onUpdate: Cascade)
  }

enum TipoNoticia {
  GERAL
  AVISO
  EVENTO
}

model Categoria {
  id Int @id @default(autoincrement())
  nome String @unique
  denuncias Denuncia[]
}

model ApoiosDenuncia {
  id Int @id @default(autoincrement())
  idUsuario Int
  idDenuncia Int
  usuario Usuario @relation(fields: [idUsuario], references: [id], onDelete: Cascade, onUpdate: Cascade)
  denuncia Denuncia @relation(fields: [idDenuncia], references: [id], onDelete: Cascade, onUpdate: Cascade)
  @@unique([idUsuario, idDenuncia])
}

model ReportsDenuncia {
  id Int @id @default(autoincrement())
  idUsuario Int
  idDenuncia Int
  usuario Usuario @relation(fields: [idUsuario], references: [id], onDelete: Cascade, onUpdate: Cascade)
  denuncia Denuncia @relation(fields: [idDenuncia], references: [id], onDelete: Cascade, onUpdate: Cascade)
  @@unique([idUsuario, idDenuncia])
}

model ApoiosComentario {
  id Int @id @default(autoincrement())
  idUsuario Int
  idComentario Int
  usuario Usuario @relation(fields: [idUsuario], references: [id], onDelete: Cascade, onUpdate: Cascade)
  comentario Comentario @relation(fields: [idComentario], references: [id], onDelete: Cascade, onUpdate: Cascade)
  @@unique([idUsuario, idComentario])
}

model ReportsComentario {
  id Int @id @default(autoincrement())
  idUsuario Int
  idComentario Int
  usuario Usuario @relation(fields: [idUsuario], references: [id], onDelete: Cascade, onUpdate: Cascade)
  comentario Comentario @relation(fields: [idComentario], references: [id], onDelete: Cascade, onUpdate: Cascade)
  @@unique([idUsuario, idComentario])
}